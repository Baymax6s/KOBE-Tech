# API base URL (デフォルト: http://localhost:8080)
# VITE_API_BASE_URL=http://localhost:8080

# MSW を利用する場合のみ true
VITE_USE_MSW=false

# Markdown 記法チートシート記事の ID（数値）
# seed (20260520130000_seed_markdown_cheatsheet_article) 適用後の連番で 6 番目に投入される。
# 未設定の場合、新規記事作成画面のチートシートボタンは
# 外部遷移せずダイアログでチートシートを表示するフォールバックになる。
VITE_HELP_ARTICLE_MARKDOWN_ID=6